# Polymarket Trading Bot - Environment Configuration Template
# This template uses 1Password references (op://)
# To use: op inject -i .env.template -o .env
# Or: op run --env-file=.env.template -- python -m cmd.bot

# ============================================
# Polymarket API Configuration
# ============================================
POLYMARKET_PRIVATE_KEY=op://Trading/Polymarket/private_key
POLYMARKET_FUNDER_ADDRESS=op://Trading/Polymarket/funder_address

# ============================================
# Builder Configuration (Optional)
# ============================================
BUILDER_ENABLED=op://Trading/Builder/enabled
BUILDER_API_KEY=op://Trading/Builder/api_key
BUILDER_SECRET=op://Trading/Builder/secret
BUILDER_PASSPHRASE=op://Trading/Builder/passphrase

# ============================================
# Email Notifications (Optional)
# ============================================
ENABLE_EMAIL_ALERTS=op://Trading/Email/enable_alerts
SMTP_SERVER=op://Trading/Email/smtp_server
SMTP_PORT=op://Trading/Email/smtp_port
SMTP_USERNAME=op://Trading/Email/username
SMTP_PASSWORD=op://Trading/Email/app_password
ALERT_EMAIL_FROM=op://Trading/Email/from
ALERT_EMAIL_TO=op://Trading/Email/to

# ============================================
# Discord Notifications (Optional)
# ============================================
ENABLE_DISCORD_ALERTS=op://Trading/Discord/enable_alerts
DISCORD_WEBHOOK_URL=op://Trading/Discord/webhook_url
DISCORD_MENTION_USER_ID=op://Trading/Discord/mention_user_id

# ============================================
# Paper Trading Settings
# ============================================
PAPER_TRADING_ENABLED=op://Trading/PaperTrading/enabled
PAPER_TRADING_ONLY=op://Trading/PaperTrading/only
FAKE_CURRENCY_BALANCE=op://Trading/PaperTrading/fake_balance

# ============================================
# Dashboard Configuration
# ============================================
DASHBOARD_ENABLED=op://Trading/Dashboard/enabled
DASHBOARD_PORT=op://Trading/Dashboard/port
DASHBOARD_HOST=op://Trading/Dashboard/host

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=op://Trading/Logging/level
LOG_TO_FILE=op://Trading/Logging/to_file

# ============================================
# Arbitrage Strategy Configuration
# ============================================
EXECUTE_BEFORE_CLOSE_SECONDS=op://Trading/Strategy/execute_before_close
MIN_PRICE_THRESHOLD=op://Trading/Strategy/min_price_threshold
MAX_PRICE_THRESHOLD=op://Trading/Strategy/max_price_threshold
MAX_POSITIONS=op://Trading/Strategy/max_positions
CAPITAL_SPLIT_PERCENT=op://Trading/Strategy/capital_split_percent
SCAN_INTERVAL_MS=op://Trading/Strategy/scan_interval_ms

# ============================================
# Market Categories
# ============================================
ENABLE_CRYPTO_MARKETS=op://Trading/Categories/crypto_enabled
ENABLE_FED_MARKETS=op://Trading/Categories/fed_enabled
ENABLE_REGULATORY_MARKETS=op://Trading/Categories/regulatory_enabled
ENABLE_OTHER_MARKETS=op://Trading/Categories/other_enabled

# ============================================
# Category Priority
# ============================================
PRIORITY_CRYPTO=op://Trading/Categories/crypto_priority
PRIORITY_FED=op://Trading/Categories/fed_priority
PRIORITY_REGULATORY=op://Trading/Categories/regulatory_priority
PRIORITY_OTHER=op://Trading/Categories/other_priority

# ============================================
# Keyword Filters (comma-separated)
# ============================================
CRYPTO_KEYWORDS=op://Trading/Keywords/crypto
FED_KEYWORDS=op://Trading/Keywords/fed
REGULATORY_KEYWORDS=op://Trading/Keywords/regulatory
OTHER_KEYWORDS=op://Trading/Keywords/other

# ============================================
# Exclude Filters (comma-separated)
# ============================================
EXCLUDE_KEYWORDS=op://Trading/Keywords/exclude
EXCLUDE_SLUGS=op://Trading/Keywords/exclude_slugs

# ============================================
# Time Filters
# ============================================
MIN_TIME_TO_CLOSE=op://Trading/Time/close_min
MAX_TIME_TO_CLOSE=op://Trading/Time/close_max

# ============================================
# Edge Filters
# ============================================
MIN_EDGE=op://Trading/Edge/min_edge
MAX_EDGE=op://Trading/Edge/max_edge

# ============================================
# Scanning Behavior
# ============================================
MAX_MARKETS_TO_TRACK=op://Trading/Scanning/max_markets
TRACK_NEW_MARKETS_ONLY=op://Trading/Scanning/new_only
IGNORE_SEEN_MARKETS=op://Trading/Scanning/ignore_seen

# ============================================
# Execution Settings
# ============================================
ORDER_TYPE=op://Trading/Execution/order_type
SLIPPAGE_TOLERANCE_PERCENT=op://Trading/Execution/slippage
MAX_RETRIES=op://Trading/Execution/max_retries
RETRY_DELAY_MS=op://Trading/Execution/retry_delay

# ============================================
# Additional Settings
# ============================================
TARGETED_SCANNING_ENABLED=op://Trading/Scanning/targeted_enabled
TARGETED_MARKET_SCAN_INTERVAL_MINUTES=op://Trading/Scanning/targeted_interval
TARGETED_MARKET_KEYWORDS=op://Trading/Scanning/targeted_keywords
SLEEP_ON_NO_OPPORTUNITIES=op://Trading/Scanning/sleep_on_no_opp
SLEEP_DURATION_MINUTES=op://Trading/Scanning/sleep_duration
