# Polymarket Trading Bot - Configuration Example
# Copy this file to .env and fill in your values

# ============================================
# Polymarket API Configuration
# ============================================
POLYMARKET_PRIVATE_KEY=your_private_key_here
POLYMARKET_FUNDER_ADDRESS=your_funder_address_here

# ============================================
# Relayer Configuration (Optional — takes priority over Builder)
# ============================================
# Relayer keys give unlimited relay transactions for a single wallet
# without tier approval. Generate at: polymarket.com/settings?tab=api-keys
# Docs: https://docs.polymarket.com/trading/gasless
RELAYER_ENABLED=false
RELAYER_API_KEY=
RELAYER_API_KEY_ADDRESS=

# ============================================
# Builder Configuration (Optional)
# ============================================
# BUILDER_TIER options: unverified (100/day) | verified (3000/day) | partner (unlimited)
# Apply for verified/partner at builder@polymarket.com
BUILDER_ENABLED=false
BUILDER_TIER=unverified
BUILDER_API_KEY=
BUILDER_SECRET=
BUILDER_PASSPHRASE=

# ============================================
# Email Notifications (Optional)
# ============================================
ENABLE_EMAIL_ALERTS=true
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
ALERT_EMAIL_FROM=bot@yourdomain.com
ALERT_EMAIL_TO=your_email@gmail.com

# ============================================
# Discord Notifications (Optional)
# ============================================
ENABLE_DISCORD_ALERTS=true
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN
DISCORD_MENTION_USER=@yourusername

# ============================================
# Trading Mode & Strategy
# ============================================
# paper      - real Polymarket API prices, simulated execution (no real money)
# simulation - fully offline, synthetic market data, no API calls
TRADING_MODE=paper
PAPER_TRADING_ONLY=true
FAKE_CURRENCY_BALANCE=10000.00

# Name of the strategy to load from strategies/registry.py
# Options: example_strategy | showcase_demo | crypto_5min_mm | paper_demo | demo_buy
STRATEGY=example_strategy

# ============================================
# Crypto 5-Minute Market-Making (crypto_5min_mm)
# ============================================
# Uncomment the block below to run the crypto 5-minute market-making strategy.
# Requires POLYMARKET_PRIVATE_KEY and POLYMARKET_FUNDER_ADDRESS to be set above.
# The strategy files are kept private and not included in this repository.
#
# STRATEGY=crypto_5min_mm
# TRADING_MODE=paper
# PAPER_TRADING_ONLY=true
# SCAN_CATEGORIES=crypto
# SCAN_INTERVAL_MS=300000
# MAX_POSITIONS=3
# CAPITAL_SPLIT_PERCENT=0.2

# ============================================
# Dashboard Demo (showcase_demo strategy)
# ============================================
# Uncomment the block below to run a fully offline demo that populates all
# dashboard charts with realistic synthetic trading data.  No API keys needed.
#
# STRATEGY=showcase_demo
# TRADING_MODE=simulation
# PAPER_TRADING_ONLY=true
# FAKE_CURRENCY_BALANCE=10000.00
# MAX_POSITIONS=5
# CAPITAL_SPLIT_PERCENT=8
# SCAN_INTERVAL_MS=20000

# ============================================
# Dashboard Configuration
# ============================================
DASHBOARD_ENABLED=true
DASHBOARD_PORT=8080
# Localhost only by default. Set to 0.0.0.0 only if you need remote access
# and have a reverse proxy with authentication in front of the dashboard.
DASHBOARD_HOST=127.0.0.1
# Optional API key for dashboard authentication.
# When set, all endpoints (except /api/health) require the header:
#   X-API-Key: <your-key>
# Leave empty to disable auth (safe when DASHBOARD_HOST=127.0.0.1).
# Recommended when setting DASHBOARD_HOST=0.0.0.0.
DASHBOARD_API_KEY=

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=INFO
LOG_TO_FILE=true

# ============================================
# Database Configuration
# ============================================
DB_ENABLED=true
DB_PATH=./storage/trading.db

# ScyllaDB — order book snapshot storage (disabled by default, requires Docker)
SCYLLA_ENABLED=false
SCYLLA_HOST=127.0.0.1
SCYLLA_PORT=9042
SCYLLA_KEYSPACE=polymarket

# ============================================
# Session Tracking & Ollama Review
# ============================================
# Directory where per-session JSON exports are written (auto-created)
SESSIONS_DIR=./logs/sessions
# Enable Ollama review generation on bot shutdown
# Set to true when running via Docker Compose (ollama service must be healthy)
OLLAMA_ENABLED=false
# Ollama server URL — use http://ollama:11434 inside Docker Compose.
# IMPORTANT: Do NOT point this at a public or third-party Ollama host.
# The review prompt contains trading performance data (P&L, win rate,
# market slugs). A remote host would receive that data over the network.
OLLAMA_HOST=http://localhost:11434
# Model for review generation — pulled automatically on first use (~2 GB)
OLLAMA_MODEL=llama3.2:3b

# ============================================
# Strategy Execution
# ============================================
MAX_POSITIONS=5
CAPITAL_SPLIT_PERCENT=0.2
# Percent drop from entry price that triggers an early sell (0 = disabled)
STOP_LOSS_PERCENT=0
# Minimum confidence score (0.0–1.0) to enter a trade
MIN_CONFIDENCE=0.5
# Minimum USD volume a market must have to be considered
MIN_VOLUME_USD=1000.0
# Market categories to scan (comma-separated)
SCAN_CATEGORIES=crypto,fed,regulatory,other

# ============================================
# Scanning Configuration
# ============================================
# WARNING: Each scan makes ~4 API calls (one per market category).
# Safe minimums per builder tier:
#   unverified — 100 tx/day  → ~3,456,000 ms (~57 min)
#   verified   — 3000 tx/day →   ~115,200 ms (~2 min)
#   partner    — unlimited   →    ~30,000 ms (30s default)
SCAN_INTERVAL_MS=30000

# ============================================
# Market Categories
# ============================================
ENABLE_CRYPTO_MARKETS=true
ENABLE_FED_MARKETS=true
ENABLE_REGULATORY_MARKETS=true
ENABLE_OTHER_MARKETS=true

# ============================================
# Category Priority (1=highest)
# ============================================
PRIORITY_CRYPTO=1
PRIORITY_FED=2
PRIORITY_REGULATORY=3
PRIORITY_OTHER=4

# ============================================
# Execution Settings
# ============================================
SLIPPAGE_TOLERANCE_PERCENT=5.0
# Polymarket taker fee percent (used for net edge calculation)
TAKER_FEE_PERCENT=2.0
MAX_RETRIES=3
RETRY_DELAY_MS=100

# ============================================
# Paper Demo Strategy
# ============================================
# These override strategies/paper_demo/config.yaml
HOLD_SECONDS=300
MIN_VOLUME=500.0
PRIMARY_SCAN_CATEGORY=crypto

# ============================================
# Enhanced Market Scanner Strategy
# ============================================
# These override strategies/enhanced_market_scanner/config.yaml
MIN_EDGE=0.5
MAX_EDGE=5.0
MIN_TIME_TO_CLOSE=60
MAX_TIME_TO_CLOSE=86400
MAX_MARKETS_TO_TRACK=1000
TRACK_NEW_MARKETS_ONLY=false
IGNORE_SEEN_MARKETS=false

# Keyword Filters (comma-separated, enhanced_market_scanner only)
CRYPTO_KEYWORDS=bitcoin,ethereum,crypto,defi,web3
FED_KEYWORDS=federal,reserve,fed,interest rate,inflation,economy
REGULATORY_KEYWORDS=sec,regulation,compliance,government,fed chair,powell
OTHER_KEYWORDS=politics,election,sports,entertainment,celebrity

# Exclude Filters (comma-separated, enhanced_market_scanner only)
EXCLUDE_KEYWORDS=trump,biden,presidential,prediction,speculative,gambling,uncertain
EXCLUDE_SLUGS=trump-biden-prediction,speculative-market-id1,uncertain-outcome

# ============================================
# Power Management (Windows only)
# ============================================
# Prevent the laptop from sleeping while the bot runs.
#
# PREVENT_SLEEP=true  blocks Windows idle sleep (inactivity / screensaver).
#
# To ALSO keep the bot running when the lid is closed:
#   Windows Settings → System → Power & sleep → Additional power settings
#   → "Choose what closing the lid does"
#   → Set "When I close the lid" to "Do nothing" (battery AND plugged in)
#
PREVENT_SLEEP=false

# ============================================
# External Data APIs
# ============================================
# Master toggle — set false to disable all external API calls
EXTERNAL_DATA_ENABLED=true

# FRED API key (free) — get at https://fred.stlouisfed.org/docs/api/api_key.html
# Leave empty to disable Fed Funds, CPI, PCE, unemployment data.
FRED_API_KEY=

# Crypto symbols to track via Binance (comma-separated, no spaces)
# RSI is computed for each symbol (one Binance klines call per symbol per refresh)
EXTERNAL_CRYPTO_SYMBOLS=BTC,ETH,SOL

# Cache TTLs in seconds
# Crypto: 15s keeps data fresh without hammering Binance (1200 weight/min limit)
# Fear & Greed / FRED macro update daily/monthly — 1 hour is more than sufficient
EXTERNAL_CRYPTO_TTL_S=15
EXTERNAL_FNG_TTL_S=3600
EXTERNAL_MACRO_TTL_S=3600
