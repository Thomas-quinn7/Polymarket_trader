docs/DEV_GUIDE.md
docs/DATABASE_SCHEMA.md
docs/API_REFERENCE.md
docs/KNOWN_ISSUES.md
docs/BACKTEST_PLAN.md


# Backup files
*.bak
*.backup
*.old

# ============================================================
# ADDITIONAL PROTECTION
# ============================================================

# Prevent accidental commits of large files
*.zip
*.tar
*.tar.gz
*.rar

# Large binary files (adjust as needed)
*.iso
*.dmg
*.exe

# ============================================================
# EXAMPLE AND TEMPLATE FILES (SAFE TO COMMIT)
# ============================================================

# These ARE safe to commit because they contain only placeholders
# Do NOT ignore these:
# .env.example          (contains only placeholders, safe to commit)
# config.example.json   (contains only placeholders, safe to commit)

# ============================================================
# STRATEGIES (ignore live strategies, keep framework + examples)
# ============================================================
strategies/*.py
!strategies/__init__.py
!strategies/base.py
!strategies/registry.py
!strategies/config_loader.py
!strategies/examples/

# Private strategies — not for public release
strategies/crypto_5min_mm/
strategies/paper_demo/
strategies/demo_buy/
strategies/enhanced_market_scanner/