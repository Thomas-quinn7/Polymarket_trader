# ============================================================
# GITIGNORE - Comprehensive Security Configuration
# ============================================================
# This file ensures NO credentials or sensitive data are committed to Git
# ============================================================

# ============================================================
# CRITICAL SECURITY: NEVER COMMIT THESE FILES
# ============================================================

# Environment variables with REAL credentials (NEVER commit these!)
# .env is the actual configuration file - NEVER commit real credentials
# Use .env.template with 1Password references for security

# Critical: Never commit these files with real credentials
.env
.env.local
.env.*.local
# Catch all other .env variants (.env.production, .env.staging, .env.live, etc.)
.env.*
# Re-allow the safe example/template files
!.env.example
!.env.template

# API Keys and Secrets
*.key
*.secret
*.pem
*.p12
*.pfx
credentials.*
secrets.*
api_keys.*
private_keys.json

# Password files
*.password
*passwords.txt
passphrase.txt

# ============================================================
# PROJECT-SPECIFIC FILES
# ============================================================

# ── Trading data outputs (NEVER commit) ─────────────────────
#
# storage/ — SQLite database with real trade records and P&L.
#   Auto-created by the bot; all contents are runtime data.
storage/
# Allow the directory placeholder so `git clone` creates the folder.
!storage/.gitkeep

# logs/ — includes logs/sessions/*.json (per-strategy session exports
#   with trade history, equity curves, and Ollama reviews).
#   Already covered by the `logs/` rule below, listed here for clarity.

# ── Docker-mounted directories ───────────────────────────────
#
# docker-compose.yml mounts two host directories into the container:
#   ./logs    → /app/logs    (covered by `logs/` below)
#   ./storage → /app/storage (covered by `storage/` above)
#
# Docker NAMED volumes (scylla_data, ollama_data) are stored in
# Docker's internal volume store — they live outside this repository
# entirely and cannot be accidentally committed.

# Polymarket specific
data/.seen_markets.json
polymarket_private_key.txt
builder_credentials.txt
wallet_mnemonic.txt

# Alert configuration with real credentials
email_config.json
discord_config.json
alert_settings.json

# ============================================================
# BINARY FILES AND COMPILED CODE
# ============================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

