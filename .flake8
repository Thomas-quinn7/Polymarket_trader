[flake8]
max-line-length = 100
# E203: whitespace before ':' — Black intentionally formats slice notation this
# way (e.g. a[1 :]) and the two tools are known to conflict on this rule.
extend-ignore = E203
exclude =
    .venv,
    __pycache__,
    .git,
    *.egg-info,
    # Dead-code package — kept for reference, not part of the trading system
    pkg/,
    # Utility / manual test scripts that are not run in CI
    tests/scripts/,
    # Internal PDF builder scripts (gitignored on origin, only present on the
    # private remote). Their bodies are large literal strings of guide content
    # whose long lines are intentional — flake8 line-length checks aren't useful.
    build_guide_pdf.py,
    build_run_guide_pdf.py

per-file-ignores =
    # dashboard/api.py intentionally imports config after setting up module-level
    # path constants that are referenced at import time; E402 is expected here.
    dashboard/api.py: E402
    # tools/*.py are standalone scripts that run from the repo root without
    # requiring the package to be installed. They adjust sys.path before
    # importing from data/ and utils/, which trips E402 by design.
    tools/price_target_tracker.py: E402
    # Same sys.path bootstrap as above, plus an SQL UPSERT block whose lines
    # exceed 100 chars to keep the CASE/WHEN columns aligned for readability.
    tools/tick_recorder.py: E402, E501
